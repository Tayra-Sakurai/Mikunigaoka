<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="Mikunigaoka.PaymentMethodView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Mikunigaoka"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:Sakaishi.Models"
    xmlns:viewmodels="using:Sakaishi.ViewModels"
    xmlns:controls="using:Mikunigaoka.Controls"
    d:DataContext="{d:DesignInstance Type=viewmodels:PaymentMethodViewModel}"
    mc:Ignorable="d">

    <Grid RowSpacing="8"
          ColumnSpacing="4">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <controls:ValidationTextBox Text="{Binding Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                    x:Uid="PaymentMethodNameBox"/>

        <NumberBox IsEnabled="False"
                   Value="{Binding Balance, Mode=OneTime}"
                   Grid.Row="1"
                   x:Uid="BalanceBox"/>
    </Grid>
</UserControl>

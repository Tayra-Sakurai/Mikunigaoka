<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Mikunigaoka.LargeCategoryEditionPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Mikunigaoka"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewmodels="using:Sakaishi.ViewModels"
    DataContext="{x:Bind largeCategoryViewModel, Mode=OneWay}"
    d:DataContext="{d:DesignInstance Type=viewmodels:LargeCategoryViewModel}"
    mc:Ignorable="d">

    <Grid Background="{ThemeResource SolidBackgroundFillColorBaseBrush}"
          RowSpacing="8"
          ColumnSpacing="4">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock x:Uid="LargeCategoryDescriptionEdition"
                   Style="{StaticResource BodyTextBlockStyle}"/>
        <local:LargeCategoryEntryView Grid.Row="1"/>
        <CommandBar DefaultLabelPosition="Right"
                    Grid.Row="3">
            <AppBarButton Icon="Save"
                          x:Uid="LargeCategorySaveButton"
                          Command="{x:Bind largeCategoryViewModel.SaveCommand}"/>
            <AppBarButton Icon="Delete"
                          x:Uid="LargeCategoryDeleteButton"
                          Command="{x:Bind largeCategoryViewModel.DeleteCommand}"/>
        </CommandBar>
    </Grid>
</Page>

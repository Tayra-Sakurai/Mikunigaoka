<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Mikunigaoka.ItemsViewPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Mikunigaoka"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:controls="using:CommunityToolkit.WinUI.Controls"
    xmlns:behaviors="using:CommunityToolkit.WinUI.Behaviors"
    xmlns:interactivity="using:Microsoft.Xaml.Interactivity"
    xmlns:models="using:Sakaishi.Models"
    xmlns:converters="using:Sakaishi.Converters"
    mc:Ignorable="d">

    <Page.Resources>
        <XamlUICommand x:Name="SuperAdditionCommand"
                       x:Key="SuperAdditionCommand"/>

        <XamlUICommand x:Name="SuperEditCommand"
                       x:Key="SuperEditCommand"/>

        <converters:CurrencyConverter x:Key="SuperConverter"/>
    </Page.Resources>

    <Grid Background="{ThemeResource SolidBackgroundFillColorBaseBrush}"
          RowSpacing="8"
          ColumnSpacing="4">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto" MaxHeight="164"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Style="{StaticResource BodyTextBlockStyle}">
            <Run Text="{x:Bind viewModel.Items.Count}"/>
            <Run x:Uid="FoundNumberLabel"/>
        </TextBlock>

        <ListView Grid.Row="1"
                  ItemsSource="{x:Bind viewModel.Items}"
                  x:Name="SuperListView">
            <ListView.Header>
                <Border Padding="12,0,0,0"
                        Background="{ThemeResource SolidBackgroundFillColorBaseAltBrush}">
                    <interactivity:Interaction.Behaviors>
                        <behaviors:StickyHeaderBehavior/>
                    </interactivity:Interaction.Behaviors>
                    <controls:DataTable>
                        <controls:DataColumn x:Uid="IdColumn"/>
                        <controls:DataColumn x:Uid="DateTimeColumn"/>
                        <controls:DataColumn x:Uid="LargecategoryColumn" DesiredWidth="*"/>
                        <controls:DataColumn x:Uid="SmallcategoryColumn" DesiredWidth="*"/>
                        <controls:DataColumn x:Uid="ItemNameColumn" DesiredWidth="4*"/>
                        <controls:DataColumn x:Uid="PaymentMethodColumn"/>
                        <controls:DataColumn x:Uid="ExpenseColumn" DesiredWidth="2*"/>
                        <controls:DataColumn x:Uid="IncomeColumn" DesiredWidth="2*"/>
                    </controls:DataTable>
                </Border>
            </ListView.Header>
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="models:Item">
                    <controls:DataRow>
                        <TextBlock Text="{x:Bind Id}"/>
                        <TextBlock Text="{x:Bind DateTime}"/>
                        <TextBlock Text="{x:Bind Category.LargeCategory.Name}"/>
                        <TextBlock Text="{x:Bind Category.Name}"/>
                        <TextBlock Text="{x:Bind Title}"/>
                        <TextBlock Text="{x:Bind PaymentMethod.Name}"/>
                        <TextBlock Text="{x:Bind Expense, Converter={StaticResource SuperConverter}}"/>
                        <TextBlock Text="{x:Bind Income, Converter={StaticResource SuperConverter}}"/>
                    </controls:DataRow>
                </DataTemplate>
            </ListView.ItemTemplate>
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem"
                       BasedOn="{StaticResource DefaultListViewItemStyle}">
                    <Setter Property="HorizontalAlignment" Value="Stretch"/>
                </Style>
            </ListView.ItemContainerStyle>
        </ListView>

        <ListView Grid.Row="2"
                  ItemsSource="{x:Bind viewModel.Categories}"
                  SelectedItem="{x:Bind viewModel.FilteringCategory, Mode=TwoWay}">
            <ListView.ItemsPanel>
                <ItemsPanelTemplate>
                    <ItemsStackPanel AreStickyGroupHeadersEnabled="True"/>
                </ItemsPanelTemplate>
            </ListView.ItemsPanel>
            <ListView.GroupStyle>
                <GroupStyle>
                    <GroupStyle.HeaderTemplate>
                        <DataTemplate x:DataType="models:LargeCategory">
                            <TextBlock Style="{ThemeResource BodyLargeStrongTextBlockStyle}"
                                       Text="{x:Bind Name}"
                                       AutomationProperties.AccessibilityView="Raw"/>
                        </DataTemplate>
                    </GroupStyle.HeaderTemplate>
                </GroupStyle>
            </ListView.GroupStyle>
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="models:SmallCategory">
                    <Border Margin="12,0,4,0">
                        <TextBlock Style="{ThemeResource BodyLargeTextBlockStyle}"
                                   Text="{x:Bind Name}"/>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
        
        <ComboBox ItemsSource="{x:Bind viewModel.PaymentMethods, Mode=OneWay}"
                  SelectedItem="{x:Bind viewModel.PaymentMethod, Mode=TwoWay}"
                  Grid.Row="3">
            <ComboBox.ItemTemplate>
                <DataTemplate x:DataType="models:PaymentMethod">
                    <TextBlock Text="{x:Bind Name}"/>
                </DataTemplate>
            </ComboBox.ItemTemplate>
            <ComboBox.ItemContainerStyle>
                <Style TargetType="ComboBoxItem"
                       BasedOn="{StaticResource DefaultComboBoxItemStyle}"/>
            </ComboBox.ItemContainerStyle>
        </ComboBox>

        <CommandBar Grid.Row="4"
                    DefaultLabelPosition="Right">
            <AppBarButton Icon="Add"
                          x:Uid="ItemAdditionButton"
                          Command="{StaticResource SuperAdditionCommand}"/>
            <AppBarButton Icon="Delete"
                          x:Uid="ItemDeletionButton">
                <AppBarButton.Flyout>
                    <Flyout>
                        <StackPanel Orientation="Vertical">
                            <TextBlock Style="{StaticResource BodyStrongTextBlockStyle}"
                                       x:Uid="ComfirmMessageItem"/>
                            <Button x:Uid="TruelyDeleteComfirmedItemButton"
                                    Command="{x:Bind viewModel.DeleteCommand}"
                                    Style="{StaticResource AccentButtonStyle}"
                                    CommandParameter="{Binding SelectedItem, ElementName=SuperListView}"/>
                        </StackPanel>
                    </Flyout>
                </AppBarButton.Flyout>
            </AppBarButton>
            <AppBarButton Icon="Sync"
                          x:Uid="LoadingDatabaseButton"
                          Command="{x:Bind viewModel.LoadCommand}"/>
            <AppBarButton Icon="Filter"
                          x:Uid="ApplyFilterButton"
                          Command="{x:Bind viewModel.ApplyFilterCommand}"/>
            <AppBarButton Icon="Edit"
                          x:Uid="EditItemButton"
                          Command="{StaticResource SuperEditCommand}"
                          CommandParameter="{Binding SelectedItem, ElementName=SuperListView}"/>
        </CommandBar>
    </Grid>
</Page>

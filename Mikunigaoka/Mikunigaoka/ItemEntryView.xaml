<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="Mikunigaoka.ItemEntryView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Mikunigaoka"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewmodels="using:Sakaishi.ViewModels"
    xmlns:models="using:Sakaishi.Models"
    xmlns:controls="using:Mikunigaoka.Controls"
    d:DataContext="{d:DesignInstance Type=viewmodels:ItemViewModel}"
    mc:Ignorable="d">

    <Grid RowSpacing="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock x:Uid="ItemDescription"
                   Style="{StaticResource BodyTextBlockStyle}"/>

        <StackPanel Spacing="4" Orientation="Horizontal" Grid.Row="1">
            <CalendarDatePicker Date="{Binding Date, Mode=TwoWay}" x:Uid="DatePicker"/>
            <TimePicker Time="{Binding Time, Mode=TwoWay}" x:Uid="TimePicker"/>
        </StackPanel>
        
        <StackPanel Spacing="4" Orientation="Horizontal" Grid.Row="2">
            <ComboBox ItemsSource="{Binding LargeCategories, Mode=OneTime}"
                      SelectedItem="{Binding LargeCategory, Mode=TwoWay}"
                      x:Uid="LargeCategorySelector">
                <ComboBox.ItemTemplate>
                    <DataTemplate x:DataType="models:LargeCategory">
                        <TextBlock Text="{x:Bind Name}"/>
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>

            <ComboBox ItemsSource="{Binding SmallCategories, Mode=OneTime}"
                      SelectedItem="{Binding SmallCategory, Mode=TwoWay}"
                      x:Uid="SmallCategorySelector">
                <ComboBox.ItemTemplate>
                    <DataTemplate x:DataType="models:SmallCategory">
                        <TextBlock Text="{x:Bind Name}"/>
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>

            <ComboBox ItemsSource="{Binding PaymentMethods}"
                      SelectedItem="{Binding PaymentMethod}"
                      x:Uid="PaymentMethodSelector">
                <ComboBox.ItemTemplate>
                    <DataTemplate x:DataType="models:PaymentMethod">
                        <TextBlock Text="{x:Bind Name}"/>
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>
        </StackPanel>

        <controls:ValidationTextBox x:Uid="ItemTitleBox"
                                    Text="{Binding Title}"
                                    PropertyName="Title"
                                    Grid.Row="3"/>

        <controls:ValidationTextBox x:Uid="ItemDescBox"
                                    Text="{Binding Description}"
                                    PropertyName="Description"
                                    AcceptsReturn="True"
                                    Grid.Row="4"/>

        <controls:ValidationNumberBox Value="{Binding Expense}"
                                      PropertyName="Expense"
                                      x:Uid="ExpenseBox"/>

        <controls:ValidationNumberBox Value="{Binding Income}"
                                      PropertyName="Income"
                                      x:Uid="IncomeBox"/>
    </Grid>
</UserControl>
